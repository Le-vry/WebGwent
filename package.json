{
  "name": "my-website",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:render": "node scripts/render-build.mjs",
    "build:prod": "vite build --mode production",
    "start": "node build",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:if-present": "node scripts/render-build.mjs --migrate-only",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "analyze": "vite build --analyze"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "2.11.0",
    "@skeletonlabs/tw-plugin": "0.4.1",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/eslint": "^9.6.0",
    "@types/node": "^25.5.0",
    "autoprefixer": "10.4.21",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.36.0",
    "globals": "^15.0.0",
    "postcss": "8.5.3",
    "prettier": "^3.1.1",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte": "^4.2.7",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "vite": "^5.0.3",
    "vite-plugin-tailwind-purgecss": "0.3.5"
  },
  "type": "module",
  "dependencies": {
    "@floating-ui/dom": "1.6.13",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-static": "^3.0.8",
    "highlight.js": "11.11.1",
    "mdsvex": "^0.12.3",
    "pg": "^8.20.0",
    "prisma": "^7.4.2"
  },
  "postinstall": "prisma generate",
  "engines": {
    "node": ">=18"
  }
}
